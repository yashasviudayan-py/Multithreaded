# Server bind address
HOST=0.0.0.0
PORT=8080

# Tokio worker thread count (defaults to number of CPU cores)
WORKERS=4

# Log level: error | warn | info | debug | trace
LOG_LEVEL=info

# Directory to serve static files from
STATIC_DIR=./static

# Token-bucket rate limiter: max requests per second per client IP
RATE_LIMIT_RPS=100

# Maximum concurrent connections (backpressure threshold)
MAX_CONNECTIONS=10000

# --- Phase 7: HTTPS / TLS (uncomment when enabling HTTPS) ---
# TLS_CERT_PATH=/etc/ssl/certs/server.crt
# TLS_KEY_PATH=/etc/ssl/private/server.key
